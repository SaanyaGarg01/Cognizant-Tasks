<configuration>
    <!-- Configure standard output console appender -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- Structured layout pattern for log outputs -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Define log level filters -->
    <root level="debug">
        <appender-ref ref="STDOUT" />
    </root>
</configuration>
